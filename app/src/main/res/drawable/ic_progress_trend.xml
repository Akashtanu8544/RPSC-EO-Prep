<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Grid background markers for a professional look -->
    <path
        android:pathData="M3,20 L21,20 M3,4 L3,20"
        android:strokeWidth="1.2"
        android:strokeColor="#33FFFFFF"
        android:strokeLineCap="round" />

    <!-- Trend line path curving upward with gold-to-purple gradient -->
    <path
        android:pathData="M4,17 C7,16 10,11 13,10 C16,9 18,6 20.5,4.5"
        android:strokeWidth="2.5"
        android:strokeLineCap="round">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="4"
                android:startY="17"
                android:endX="21"
                android:endY="4"
                android:type="linear">
                <item
                    android:color="#7B4DFF"
                    android:offset="0.0" />
                <item
                    android:color="#FFD700"
                    android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Glowing peak node (circular star/diamond) at (20, 4) -->
    <path
        android:pathData="M20,1 L21.5,4 L24,4 L22,6 L23,9 L20,7.5 L17,9 L18,6 L16,4 L18.5,4 Z"
        android:fillColor="#FFE082" />
        
    <!-- Secondary data point circles along the curve -->
    <path
        android:pathData="M13,10m-1.5,0a1.5,1.5 0,1 1,3 0a1.5,1.5 0,1 1,-3 0"
        android:fillColor="#A855F7" />

    <path
        android:pathData="M8,14.5m-1,0a1,1 0,1 1,2 0a1,1 0,1 1,-2 0"
        android:fillColor="#7B4DFF" />
</vector>
